   "end": 20.85,
   "flag": "-"
  },
  {
   "i": 4,
   "oset": "Куыд диссаджы мӕйрухс ӕхсӕв у!",
   "rus": "Какая прекрасная лунная ночь!",
   "start": 26.79,
   "end": 30.79,
   "flag": "-"
  },
  {
