   "end": 7.88,
   "flag": "-"
  },
  {
   "i": 2,
   "oset": "Ӕз фӕстӕмӕ ӕрыздӕхдзынӕн ӕхсӕвы.",
   "rus": "Я обратно вернусь ночью.",
   "start": 7.88,
   "end": 8.7,
   "flag": "-"
  },
  {
   "i": 3,
   "oset": "Куыд талынг ӕхсӕв у!",
